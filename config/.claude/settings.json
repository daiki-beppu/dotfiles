{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Write(//**)",
      "Edit",
      "Edit(//**)",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "NotebookEdit",
      "Skill",
      "mcp__chrome-devtools",
      "mcp__plugin_context7_context7"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(chmod *)"
    ],
    "defaultMode": "plan",
    "additionalDirectories": [
      "/Users/mba/.claude",
      "/Users/mba/01-dev/dotfiles"
    ]
  },
  "model": "claude-opus-4-6",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/copy-env.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "qodo-skills@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "notion@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": false,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      },
      "autoUpdate": true
    }
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}