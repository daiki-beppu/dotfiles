{
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approved", "needs_fix", "blocked"]
    },
    "feedback": {
      "type": "string",
      "description": "needs_fix の場合の修正指示（具体的なファイル・箇所・理由）、blocked の場合の検証不能となった環境障害の内容。approved なら空文字"
    },
    "followups": {
      "type": "array",
      "description": "レビュー中に見つけたスコープ外の問題（verdict の判定材料にしない）。起票判断は Claude Code 層が行う。省略可・なければ空配列",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string", "description": "根拠（ファイル:行、観測した挙動）" }
        },
        "required": ["title", "description", "evidence"],
        "additionalProperties": false
      }
    }
  },
  "required": ["verdict", "feedback"],
  "allOf": [
    {
      "if": {
        "properties": { "verdict": { "const": "blocked" } },
        "required": ["verdict"]
      },
      "then": {
        "properties": { "feedback": { "minLength": 1 } }
      }
    }
  ],
  "additionalProperties": false
}
