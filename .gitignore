# macOS
.DS_Store

# 機密情報ファイル
*.env           # 環境変数ファイル
*.key           # 秘密鍵ファイル
*.pem           # 証明書ファイル
*secret*        # "secret"を含むファイル
*credentials*   # 認証情報ファイル

# .config 関連の除外
.config/raycast/  # Raycast設定（トークン含む）

# Nix
result
result-*

# skill-creator の評価成果物（workspace）は追跡しない
config/.claude/skills/*-workspace/
